TERMRELAY_IMAGE=ghcr.io/OWNER/termrelay:0.3.11
TERMRELAY_DOMAIN=relay.example
# 公网 Caddy 部署通过 Docker secret 文件注入 token；文件内容只放 token，末尾换行会被忽略。
# release 镜像以 UID/GID 10001 运行；生成后请 chown 10001:10001 并 chmod 400。
TERMRELAY_AUTH_TOKEN_FILE=/etc/termd/termrelay_auth_token
# 可信 relay 的 daemon registry JSON，内容为 {"daemons":[{"server_id":"...","token":"..."}]}。
# 文件同样需要对 UID/GID 10001 可读，且不能提交到 git。
TERMRELAY_DAEMON_REGISTRY_FILE=/etc/termd/termrelay-daemons.json
