{
  "name": "termd-termui-web",
  "private": true,
  "version": "0.8.14",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json --pretty false",
    "test": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:real-relay-upload-300mb": "REAL_RELAY_UPLOAD_BYTES=314572800 playwright test tests/termui-web.real-relay.spec.ts -g \"relay Web \u4e0a\u4f20\u6587\u4ef6\" --project=chromium"
  },
  "dependencies": {
    "@dicebear/core": "10.2.0",
    "@dicebear/styles": "10.2.0",
    "@noble/ciphers": "^1.3.0",
    "@noble/curves": "^1.9.1",
    "@noble/hashes": "^1.8.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "qr-scanner": "^1.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^7.1.12",
    "vitest": "^4.1.5",
    "ws": "^8.18.0"
  },
  "overrides": {
    "dompurify": "3.4.11"
  }
}
